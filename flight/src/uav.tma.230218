%{
	#include <stdio.h>
	#include <stdlib.h>
	#include <unistd.h>
	#include "nortlib.h"
	#include "globmsg.h"
%}

State initialize  {
	     > Telemetry Start
	     > Pump GC Off
	 +2  > Nitrogen Open
	 +1  > Flow main channel 1 25
	 +1  > Flow backflush channel 1 20
	 +2	 > Mode GC Init
	+25  > elec reset 2
	+10  > Mode GC Init
	 +2  validate Warmup;
}

%{
#define NUMAIRINJ 	4		// number of air injections between cal injections
#define NUMCALINJ 	1		// number of cal injections between air injections

#define PumpOFF 	450		// mbar		(pump off at greater than this press)
#define PumpON  	400		// mbar		(pump on at less than this press)
#define PumpO3OFF 	900		// mbar		(O3 and H2O pump off at greater than this press)
#define PumpO3ON  	800		// mbar		(O3 and H2O pump on at less than this press)
#define HOT_ECD1	345		// C 		(temp ECD1 needs to be before injects )
#define HOT_ECD2	345		// C 		(temp ECD2 needs to be before injects )
#define N2fail  	0		// psi		(below this value set ECDs cold)

unsigned int AirCount = 0;
unsigned int CalCount = 0;

unsigned int STATUS = 1;			// NASDAT status variable 
unsigned int STATUS_WARNING = 0;	// used with status variable
%}

State Warmup {
	{ if (( CH2_ECD/10 > HOT_ECD2 ) || ( CH3_ECD/10 > HOT_ECD1 ))
		Validate AltCheck;
	}
}

State AltCheck {
    { if ((( convert( pres_PUMP ) < PumpON ) && ( convert( pres_PUMP ) > 0 )) || (( convert( pres_extern ) < PumpON ) && ( convert( pres_extern ) > 0 ))) 
		Validate InletPumpOn;
	  else
		Validate CalInjections;
	}
}

State CalInjections {
	    > sample cal
	+1  > solenoid Samp Out Open
	    > solenoid Samp In Open
		{ msg( 0, "Starting Cal Seq. (pres_extern = %6.1f)", convert( pres_extern ) ); }
	+10 > Mode GC Run 
	    { STATUS = 1 + 2 + 4 + STATUS_WARNING; }
        { if ((( convert( pres_PUMP ) < PumpON ) && ( convert( pres_PUMP ) > 0 )) || (( convert( pres_extern ) < PumpON ) && ( convert( pres_extern ) > 0 ))) 
			Validate InletPumpON;
		}
}

State InletPumpOff {
	+1	> Pump GC Off
	    { msg( 0, "Turning GC Pump OFF (pres_extern = %6.1f)", convert( pres_extern ) ); }
	+1	> Mode GC Init
        { if ((( convert( pres_PUMP ) < PumpON ) && ( convert( pres_PUMP ) > 0 )) || (( convert( pres_extern ) < PumpON ) && ( convert( pres_extern ) > 0 ))) 
			Validate InletPumpON;
		}
}

State InletPumpON {
	+1	> Pump GC On
		{ msg( 0, "Turning Pumps ON (pres_extern = %6.1f)", convert( pres_extern ) ); 
		AirCount = 0;
		CalCount = 0; }
		Validate SSVtableInit;
	+1	> Mode GC Run
	    { STATUS = 1 + 2 + STATUS_WARNING; }
		{ if ( convert( pres_extern ) >= PumpOFF ) 
			Validate InletPumpOFF;
		}
}

PARTITION
State O3AltCheck {
    { if ((( convert( pres_PUMP ) < PumpO3ON ) && ( convert( pres_PUMP ) > 0 )) || (( convert( pres_extern ) < PumpO3ON ) && ( convert( pres_extern ) > 0 ))) 
		Validate O3PumpOn;
	}
}

State O3PumpOff {
	+1	> Pump Ozone Off
	    { msg( 0, "Turning O3 Pump OFF (pres_extern = %6.1f)", convert( pres_extern ) ); }
	+1	> Pump Ozone Off
        { if ((( convert( pres_PUMP ) < PumpO3ON ) && ( convert( pres_PUMP ) > 0 )) || (( convert( pres_extern ) < PumpO3ON ) && ( convert( pres_extern ) > 0 ))) 
			Validate O3PumpON;
		}
}

State O3PumpON {
	+1	> Pump Ozone On
	    { msg( 0, "Turning O3 Pump ON (pres_extern = %6.1f)", convert( pres_extern ) ); }
	+1	> Pump Ozone On
		{ if ( convert( pres_extern ) >= PumpO3OFF ) 
			Validate O3PumpOFF;
		}
}

PARTITION
State Idle {}

State SSVtableInit {
	depending on ( Injecting2 ) { 
		Validate SSVtable;
	}
}

State SSVtable {

	depending on ( 1 Hz ) {
		depending on ( Injecting1 ) { 
			if ( CalCount < NUMCALINJ ) 
				Validate CALnext;
			else  
				Validate AIRnext;
		}

		depending on ( Injecting2 ) { 
			if ( CalCount < NUMCALINJ ) 
				Validate CALnext;
			else  
				Validate AIRnext;
		}
		
		depending on ( NotInjecting ) {
			AirCount = 0;
			CalCount = 0;
			Validate SSVtableInit;
		}

	}	
}

State AIRnext {
	+2 > Sample Air
	   { if ( ++AirCount == NUMAIRINJ ) {
			AirCount = 0;
			CalCount = 0;
		 }
	   }
	   { STATUS = 1 + 2 + STATUS_WARNING; }
	+1 Validate SSVtable;
}

State CALnext {
	+2 > Sample Cal
	   { if ( ++CalCount == NUMCALINJ ) CalCount = 500; }
	   { STATUS = 1 + 2 + 4 + STATUS_WARNING; }
	+1 Validate SSVtable;
}


# The following partition sends data to the NASDAT box.
%{
#include "nasdat.h"
char nasdatMSG[NASDAT_MAXDATA];
%}
PARTITION
State NASDAT_eng {

	{	sprintf( nasdatMSG, "xUCATS:%02d", STATUS );
		nasdat_format_a( nasdatMSG, "%06.1f", o3xbest );
		nasdat_format_f( nasdatMSG, "%06.1f", MR_N2O );
		nasdat_format_f( nasdatMSG, "%06.2f", MR_SF6 );
		nasdat_format_f( nasdatMSG, "%06.1f", MR_CFC11 );
		nasdat_format_f( nasdatMSG, "%06.1f", MR_CFC12 );
		nasdat_format_f( nasdatMSG, "%06.1f", MR_CH4 );
		sprintf( nasdatMSG, "%s\n", nasdatMSG );
		/* msg( 0, "** NASDAT: %s", nasdatMSG ); */
		send2nasdat( &nasdatMSG );
	}
} 

# The following partition sends data to the KUDATA sent via the linksys box.
%{
#include "kuband.h"
char kuMSG[KUDATA_MAXDATA];
%}
PARTITION
State KUDATA_eng {

	depending on (1 Hz) {	
		/* Edited for low bandwidth arctic portion of SABER, break packet into four
		   pieces (packets 0-3) and removed variable labels. 230106 GSD
		   Maximum packet length is set in kuband.h
		   There are four parameters for the KUformat functions.  The first is the kuMSG
		   array followed by text, usually a variable name and a format string.  The third
		   is the tmc variable, the fourth is the low value.  Below this value a NaN is sent.
		   All UCATS data, including 2 second ozone, are now in the single user packet for DCOTSS.
		*/
		
		sprintf(kuMSG, "\0");

		if (CUMSEC % 4 == 0) {
            KUformat_f(kuMSG, "%6.1f", 	convert(flow_M1), 		0);  /* flow_M1 */
            KUformat_f(kuMSG, "%6.1f", 	convert(flow_BF1), 		0);  /* flow_BF1 */
            KUformat_f(kuMSG, "%6.1f", 	convert(pres_BP1), 		0);  /* pres_BP1 */
            KUformat_f(kuMSG, "%6.1f", 	convert(pres_ECD1), 	0);  /* pres_ECD1 */
            KUformat_f(kuMSG, "%6.1f", 	convert(temp_SL1),	  -30);  /* temp_SL1 */
            KUformat_f(kuMSG, "%6.1f", 	convert(flow_M2), 		0);  /* flow_M2 */
            KUformat_f(kuMSG, "%6.1f", 	convert(flow_BF2),		0);  /* flow_BF2 */
            KUformat_f(kuMSG, "%6.1f", 	convert(pres_BP2), 		0);  /* pres_BP2 */
            KUformat_f(kuMSG, "%6.1f", 	convert(pres_ECD2), 	0);  /* pres_ECD2 */
            KUformat_f(kuMSG, "%6.1f", 	convert(temp_SL2), 	  -30);  /* temp_SL2 */
            KUformat_f(kuMSG, "%6.1f", 	convert(flow_M3), 		0);  /* flow_M3 */
            KUformat_f(kuMSG, "%6.1f", 	convert(flow_BF3),		0);  /* flow_BF3 */
            KUformat_f(kuMSG, "%6.1f", 	convert(pres_BP3), 		0);  /* pres_BP3 */
            KUformat_f(kuMSG, "%6.1f", 	convert(pres_ECD3), 	0);  /* pres_ECD3 */
            KUformat_f(kuMSG, "%6.1f", 	convert(temp_SL3), 	  -30);  /* temp_SL3 */
            send2kuband("0", &kuMSG);
            
        } else if (CUMSEC % 4 == 1) {
            KUformat_f(kuMSG, "%6.1f", 	CH1_ECD/10., 			0);  /* CH1_ECD */
            KUformat_f(kuMSG, "%6.1f", 	CH1_Col/10., 			0);  /* CH1_Col */
            KUformat_f(kuMSG, "%6.1f", 	CH2_ECD/10., 			0);  /* CH2_ECD */
            KUformat_f(kuMSG, "%6.1f", 	CH2_Col/10., 			0);  /* CH2_Col */
            KUformat_f(kuMSG, "%6.1f", 	CH3_ECD/10., 			0);  /* CH3_ECD */
            KUformat_f(kuMSG, "%6.1f", 	CH3_Col/10., 			0);  /* CH3_Col */
            KUformat_f(kuMSG, "%6.1f", 	CH3_Post/10., 			0);  /* CH3_Post */
            KUformat_d(kuMSG, "%ld", 	ecdA_CH1, 				0);  /* ecdA_CH1 */
            KUformat_d(kuMSG, "%ld", 	ecdA_CH2, 				0);  /* ecdA_CH2 */
            KUformat_d(kuMSG, "%ld", 	ecdA_CH3, 				0);  /* ecdA_CH3 */
            send2kuband("1", &kuMSG);
        
        } else if (CUMSEC % 4 == 2) {
		
            KUformat_f(kuMSG, "%6.1f", 	convert(flow_SL), 		0);  /* flow_SL */
            KUformat_f(kuMSG, "%6.1f", 	convert(pres_SL), 		0);  /* pres_SL */
            KUformat_f(kuMSG, "%6.1f", 	convert(pres_PUMP), 	0);  /* pres_PUMP */
            KUformat_f(kuMSG, "%6.1f", 	convert(pres_extern), 	0);  /* pres_extern */
            KUformat_f(kuMSG, "%6.1f", 	convert(presL_dope), 	0);  /* presL_dope */
            KUformat_f(kuMSG, "%6.1f", 	convert(presL_cal), 	0);  /* presL_cal */
            KUformat_f(kuMSG, "%6.1f", 	convert(presL_N2), 		0);  /* presL_N2 */
            KUformat_f(kuMSG, "%6.1f", 	convert(presH_123), 	0);  /* presH_123 */
            KUformat_f(kuMSG, "%6.1f",	convert(temp_gasB_N), -30);  /* temp_gasB_N */
            KUformat_f(kuMSG, "%6.1f", 	convert(temp_gasB_C), -30);  /* temp_gasB_C */
            KUformat_f(kuMSG, "%6.1f", 	convert(temp_pump),	  -50);  /* temp_pump */
            KUformat_f(kuMSG, "%6.1f", 	convert(temp_amb), 	  -30);  /* temp_amb */
            KUformat_f(kuMSG, "%7.3f", 	convert(volt_5), 		0);  /* volt_5 */
            KUformat_f(kuMSG, "%6.2f", 	convert(volt_15), 	  -20);  /* volt_15 */
            KUformat_f(kuMSG, "%6.2f", 	convert(volt_28), 		0);  /* volt_28 */
            send2kuband("2", &kuMSG);
            
        } else {
            KUformat_f(kuMSG, "%6.1f", 	o3x, 				 -500);  /* o3x */
            KUformat_f(kuMSG, "%6.1f", 	o3xtemp, 				0);  /* o3xtemp */
            KUformat_f(kuMSG, "%6.1f", 	o3xpres,				0);  /* o3xpres */
            KUformat_f(kuMSG, "%d", 	o3xflowa,				0);  /* o3xflowa */
            KUformat_f(kuMSG, "%d", 	o3xflowb,				0);  /* o3xflowb */
            send2kuband("3", &kuMSG);
		}
	}
} 


