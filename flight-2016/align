if [ $# != 1 ]; then
	echo "Usage: align [valve address]"
	echo "  exp: align 4"
	exit
fi

VALVE=$1

echo "Sending INIT to valve #$1"
valco -c ${VALVE}in
sleep 2
echo "Toggle 1"
valco -c ${VALVE}to
sleep 2
