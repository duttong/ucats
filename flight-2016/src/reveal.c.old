#include <stdio.h>
#include <stdlib.h>
#include <sys/kernel.h>
#include <sys/name.h>
#include <sys/proxy.h>
#include <string.h>
#include <unistd.h>
#include "regnames.h"
#include "reveal.h"

// send data to the reveal driver
int send2reveal( char *Smsg, int len ) {
	pid_t 	rs_pid;
 	char 	Rmsg[5];
	char	rvl[REVEAL_MAXDATA+2];

	rvl[0] = msg_RVLdata;		// data message
	rvl[1] = len;				// charaters in data 
	strcat( rvl,  Smsg );
	strcat( rvl, "\n" );

	// find REVEAL ethernet driver
	if ((rs_pid = qnx_name_locate (0, NAME_REVEAL, 0, NULL)) == -1) {
		// can't find 
		//perror("can't locate reveal");
		return 0;
	}

	Send(rs_pid, rvl, Rmsg, len+2, sizeof(Rmsg));

	return 1;

}
