	-0.00002, -999.9,
	-0.00001, -999.9,
	0 , 99,
	5, -44
}


TM typedef adrA SCCM { text "%6.1f"; convert FLOW; }
Calibration ( SCCM, FLOW ) {
	-0.02, -999.9,
	-0.01, -999.9,
	0.0,   -1, 
	0.5,    0,
	2.5,   150
}

