TM typedef float VOL5;
TM typedef float TEMP;
TM typedef float FLOW;
TM typedef float PRESS;
TM typedef float ANLU { text "%6.1f"; }
TM typedef float ANLU3 { text "%6.3f"; }



TM typedef adrA VOLTS { text "%6.1f"; convert VOL5; }
Calibration ( VOLTS, VOL5 ) {
	-0.00002, -999.9,
	-0.00001, -999.9,
	0, 0,
	5, 5
}


TM typedef adrA VOLTS512 { text "%6.1f"; convert VOL5; }
Calibration ( VOLTS512, VOL5 ) {
	-0.00002, -999.9,
	-0.00001, -999.9,
	0, 0,
	5, 15.8
}


TM typedef adrA VOLTSPM { text "%6.1f"; convert VOL5; }
Calibration ( VOLTSPM, VOL5 ) {
	-5.0002, -999.9,
	-5.0001, -999.9,
	-5, -15.9,
	5, 15.9
}



TM typedef adrA VOLTS28 { text "%6.1f"; convert VOL5; }
